digraph pipeline {
    rankdir = LR;
    node[shape = box, style = rounded, fontsize = 10];

    // Stages
    IF[label = "Instruction Fetch (IF)"];
    IFID[label = "IF/ID Register"];
    ID[label = "Instruction Decode (ID)\n- Control Unit\n- Reg File\n- Imm Gen\n- Hazard Detector"];
    IDEX[label = "ID/EX Register"];
    EX[label = "Execute (EX)\n- ALU\n- Forwarding"];
    EXMEM[label = "EX/MEM Register"];
    MEM[label = "Memory Access (MEM)\n- Data Memory"];
    MEMWB[label = "MEM/WB Register"];
    WB[label = "Write Back (WB)\n- Reg File Write"];

    // Flow
    IF -> IFID -> ID -> IDEX -> EX -> EXMEM -> MEM -> MEMWB -> WB;

    // Feedback paths
    MEMWB -> ID[label = "RegWrite (writeback)", color = blue];
    EX -> ID[label = "Forwarding", color = red];
    MEM -> ID[label = "Forwarding", color = red];
    EX -> IF[label = "Branch Target", color = green];

    // Extras
    IF -> IF[label = "PC + 4", color = gray];
}

    .reset(reset),                         ASSIGNED AS BEFORE THE CLOCK CYCLE ENDS AND THE OTHER IS READ JUS AS IT BEGINS
    .input1({curr_pc, instruction}),
    .output1({ifid_pc, ifid_instruction})
);

